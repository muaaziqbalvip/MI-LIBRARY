{
  "version": 2,
  "name": "mi-library",
  "routes": [
    { "src": "/sitemap.xml", "dest": "/api/sitemap.js" },
    { "src": "/api/download", "dest": "/api/download.js" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/sw.js", "dest": "/sw.js", "headers": { "Service-Worker-Allowed": "/" } },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    { "source": "/sw.js", "headers": [{ "key": "Cache-Control", "value": "no-cache" }, { "key": "Service-Worker-Allowed", "value": "/" }] },
    { "source": "/(.*)", "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }, { "key": "X-Frame-Options", "value": "SAMEORIGIN" }] }
  ]
}
